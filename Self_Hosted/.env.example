# Copy this file to .env before running Docker Compose.
# Change these values before using the service.

# Required. Clients send this as: Authorization: Bearer <token>
BEARER_TOKEN=change-me-long-random-token

# Required. Used for the Compose-managed PostgreSQL user.
# Keep this URL-safe because docker-compose.yml embeds it in a PostgreSQL URL.
POSTGRES_PASSWORD=change_me_url_safe_database_password

# Optional. Host/IP and port where Docker publishes the app.
# 127.0.0.1 is safest when using a local reverse proxy or local testing.
# Use APP_HOST=0.0.0.0 for production if not using a reverse proxy.
APP_HOST=127.0.0.1
APP_PORT=8080

# Optional. CIDR allow-list for the direct client IP seen by the Go service.
# Leave blank to allow any source that can reach the published app port.
ALLOWED_NET=

# Optional. App image settings. The default image is published by GitHub Actions.
METRICS_INGEST_IMAGE=ghcr.io/mefranklin6/av-system-metrics/metrics-ingest:latest
METRICS_INGEST_PULL_POLICY=always
