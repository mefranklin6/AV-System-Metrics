# Copy this file to .env before running Docker Compose.
# The database container refuses to start until its example password is changed.

# Required. Used for the Compose-managed PostgreSQL user.
# Keep this URL-safe because docker-compose.yml embeds it in a PostgreSQL URL.
POSTGRES_PASSWORD=change_me_url_safe_database_password

# The archived client sends local wall-clock timestamps without an offset.
# Set this to the IANA time zone configured on those control processors.
LEGACY_TIMEZONE=America/Los_Angeles

# Optional. Set EXPOSE_DATABASE=true to publish PostgreSQL for database tools.
EXPOSE_DATABASE=false
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432

# Host/IP and port where Docker publishes the legacy adapter.
# Remote processors require APP_HOST=0.0.0.0 or a specific server interface.
APP_HOST=127.0.0.1
APP_PORT=8080

# Strongly recommended. Restrict unauthenticated legacy requests to the control
# processor network, for example 10.20.30.0/24. Blank allows any reachable host.
ALLOWED_NET=

# Optional image and container resource settings.
LEGACY_METRICS_INGEST_IMAGE=ghcr.io/mefranklin6/av-system-metrics/legacy-metrics-ingest:main
LEGACY_METRICS_INGEST_PULL_POLICY=always
LEGACY_METRICS_INGEST_CPUS=0.50
LEGACY_METRICS_INGEST_MEMORY_LIMIT=128m
LEGACY_METRICS_INGEST_PIDS_LIMIT=100
POSTGRES_CPUS=1.00
POSTGRES_MEMORY_LIMIT=512m
POSTGRES_PIDS_LIMIT=200

#### Do not modify below this line ####
COMPOSE_PATH_SEPARATOR=:
COMPOSE_FILE=docker-compose.yml:docker-compose.database-expose-${EXPOSE_DATABASE}.yml
